# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=itdock

# Authentication — replace in .env with a secure random value
JWT_SECRET=replace-with-a-secure-random-secret
API_KEY_SALT=replace-with-an-independent-secure-random-secret
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-unique-bootstrap-password

# Application
NEXT_PUBLIC_BASE_URL=http://localhost:3000
APP_URL=http://localhost:3000
UPLOAD_DIR=./uploads
NODE_ENV=development
